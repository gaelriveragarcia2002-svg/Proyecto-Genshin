{
  "name": "proyecto-genshin-desktop",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/proyecto-genshin-desktop/src",
  "tags": [],
  "targets": {
    "tauri": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "configurations": {
        "development": {
          "command": "tauri dev --config src-tauri/tauri.development.conf.json",
          "cwd": "apps/proyecto-genshin-desktop"
        },
        "qa": {
          "command": "tauri dev --config src-tauri/tauri.qa.conf.json",
          "cwd": "apps/proyecto-genshin-desktop"
        },
        "production": {
          "command": "tauri build",
          "cwd": "apps/proyecto-genshin-desktop"
        }
      }
    },
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/proyecto-genshin-desktop",
        "browser": "apps/proyecto-genshin-desktop/src/main.ts",
        "tsConfig": "apps/proyecto-genshin-desktop/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/proyecto-genshin-desktop/public"
          }
        ],
        "styles": ["apps/proyecto-genshin-desktop/src/styles.css"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "qa": {
          "optimization": true,
          "extractLicenses": true,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/proyecto-genshin-desktop/src/environments/environment.ts",
              "with": "apps/proyecto-genshin-desktop/src/environments/environment.qa.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/proyecto-genshin-desktop/src/environments/environment.ts",
              "with": "apps/proyecto-genshin-desktop/src/environments/environment.development.ts"
            }
          ]
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "defaultConfiguration": "development",
      "configurations": {
        "production": {
          "buildTarget": "proyecto-genshin-desktop:build:production"
        },
        "qa": {
          "buildTarget": "proyecto-genshin-desktop:build:qa"
        },
        "development": {
          "buildTarget": "proyecto-genshin-desktop:build:development"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "watch": false
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "proyecto-genshin-desktop:build",
        "port": 4200,
        "staticFilePath": "dist/apps/proyecto-genshin-desktop/browser",
        "spa": true
      }
    }
  }
}
