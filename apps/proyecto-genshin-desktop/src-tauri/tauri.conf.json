{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "proyecto-genshin-desktop",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "devUrl": "http://localhost:4200",
    "frontendDist": " ../../../dist/apps/proyecto-genshin-desktop/browser",
    "beforeDevCommand": "pnpm nx serve proyecto-genshin-desktop",
    "beforeBuildCommand": "pnpm nx build proyecto-genshin-desktop"
  },
  "app": {
    "windows": [
      {
        "title": "Proyecto-Genshin",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
